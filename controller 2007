	function sinteseFatica($textoOriginal)
	{
		$textoSemAcento = iconv('UTF-8', 'ASCII//TRANSLIT//IGNORE', $textoOriginal);
		$texto = strtolower($textoSemAcento);
		$empresasEncontradas = [];
		$dicionarioRe = [
			'Caixa Vida e Previdência S/A' => ['caixa vida', 'cvp'],
			'Caixa Seguradora S/A' => ['caixa seguradora', 'csh'],
			'Caixa Econômica Federal' => ['caixa economica', 'cef']
		];

		foreach ($dicionarioRe as $nomeFormatado => $palavras) {
			foreach ($palavras as $palavra) {
				if (strpos($texto, $palavra) !== false) {
					$empresasEncontradas[] = $nomeFormatado;
					break;
				}
			}
		}
		$nome_empresa = !empty($empresasEncontradas) ? implode(', ', $empresasEncontradas) : null;
		$alegacao = null;
		$dicionarioCausa = [
			'Descontos indevidos' => ['cobranca indevida', 'desconto indevido', 'debitos duplicados', 'valores cobrados indevidamente'],
			'Negativa de pagamento de seguro' => ['negou o requerimento de sinistro', 'nao pagamento do seguro', 'nao foi lhe conferido tal direito', 'recusa no pagamento'],
			'Fraude bancária / Empréstimo não contratado' => ['emprestimo nao contratado', 'fraude', 'desconhece a contratacao']
		];

		foreach ($dicionarioCausa as $causaFormatada => $palavras) {
			foreach ($palavras as $palavra) {
				if (strpos($texto, $palavra) !== false) {
					$alegacao = $causaFormatada;
					break 2;
				}
			}
		}
		$pedidosEncontrados = [];
		$dicionarioPedidos = [
			'devolução dos valores pagos' => ['ressarcimento', 'devolucao das parcelas', 'dano material', 'devolucao integral', 'repeticao do indebito'],
			'danos morais' => ['danos morais', 'dano moral'],
			'pagamento da apólice do seguro' => ['pagamento do capital do seguro', 'pagamento da indenizacao', 'pagamento do seguro'],
			'cancelamento do contrato' => ['cancelamento do seguro', 'cancelamento do contrato', 'declaracao de inexistencia']
		];

		foreach ($dicionarioPedidos as $pedidoFormatado => $palavras) {
			foreach ($palavras as $palavra) {
				if (strpos($texto, $palavra) !== false) {
					$pedidosEncontrados[] = $pedidoFormatado;
					break;
				}
			}
		}
		return [
			'empresa'  => $nome_empresa,
			'alegacao' => $alegacao,
			'pedido_1' => $pedidosEncontrados[0] ?? null,
			'pedido_2' => $pedidosEncontrados[1] ?? null
		];
	}


	function gerenciarLogDossie($conteudoLog)
	{
		$diretorio = dirname(__DIR__, 3) . '/public/automacao_dossie';
		if (!is_dir($diretorio) && !mkdir($diretorio, 0777, true)) {
			die("ERRO FATAL: Sem permissão para criar a pasta: {$diretorio}");
		}
		clearstatcache();

		//logica para ordenar do mais velho pro mais novo
		$arquivos = glob($diretorio . '/log_dossie_*.log') ?: []; //glob vê os arquivos de $diretorio ordena em um array
		usort($arquivos, function ($a, $b) {
			return filemtime($a) <=> filemtime($b); //spaceship operador <=> vai reordenando os item do array o php devolve em um formato timestamp
		});

		$arquivoMaisNovo = end($arquivos);
		$limiteTamanho = 5 * 1024 * 1024; // 5 MB

		if ($arquivoMaisNovo && filesize($arquivoMaisNovo) < $limiteTamanho) {
			$arquivoAlvo = $arquivoMaisNovo;
		} else {
			$arquivoAlvo = $diretorio . '/log_dossie_' . date('d-m-Y_H\H_i_s') . '.log';
			$arquivos[] = $arquivoAlvo; // Adiciona o novo arquivo no final da lista (sendo este o mais novo)!!!
		}

		@file_put_contents($arquivoAlvo, $conteudoLog . PHP_EOL, FILE_APPEND); //@' oculta warnings de permissão

		while (count($arquivos) > 5) {
			$arquivoParaDeletar = array_shift($arquivos);
			@unlink($arquivoParaDeletar);
		}
	}


	function limparPastaDossieCompleto($caminhoCompleto)
	{
		$pasta = dirname($caminhoCompleto);
		$arquivoParaManter = basename($caminhoCompleto);
		if (!is_dir($pasta)) {
			return false;
		}
		$itens = scandir($pasta);

		// dd($itens);

		//. é esse diretorio e .. é o diretorio pai
		foreach ($itens as $item) {
			if ($item === '.' || $item === '..' || $item === $arquivoParaManter) {
				continue;
			}

			//retorna assim: array:22 [0 => "." 1 => ".." 2 => "doc_17511_image7.png" 3 => "doc_29495_image4.png" 4 => "doc_46614_image8.png" 5 => "doc_47393_image14.png"....

			$caminhoItem = $pasta . '/' . $item;
			if (is_file($caminhoItem)) {
				unlink($caminhoItem);
			} elseif (is_dir($caminhoItem)) {
				@rmdir($caminhoItem);
			}
		}

		return true;
	}
