	// PRIMEIRA COISA QUE É EXIBIDA NA TELA
	// Não esqueça de importar a classe no topo do seu Controller:
	// use Illuminate\Pagination\LengthAwarePaginator;

	public function exibirTela(Request $request)
	{
		$porPagina = 25;
		$paginaAtual = (int) $request->get('page', 1);

		$retorno = $this->DadosdoProcesso($paginaAtual, $porPagina);

		$leituracampos = $retorno['dados'];
		$totalRegistros = $retorno['total'];

		$msgErro = 'ERRO: Falta dado';

		$dadosTratados = array_map(function ($item) use ($msgErro) {
			return [
				"20378||"               => $item["20378||"] ?? $msgErro,
				"17591||"               => $item["17591||"] ?? $msgErro,
				"20836||"               => $item["20836||"] ?? 0,
				"16107||"               => $item["16107||"] ?? $msgErro,
				"17714|| @displayName"  => $item["17714|| @displayName"] ?? $msgErro,
				"17681||"               => $item["17681||"] ?? $msgErro,
				"17684||"               => $item["17684||"] ?? $msgErro,
				"17684||nome"           => $item["17684||nome"] ?? $msgErro,
				"20554||"               => $item["20554||"] ?? $msgErro,
				"20554||nome"           => $item["20554||nome"] ?? $msgErro,
				"18156||"               => $item["18156||"] ?? $msgErro
			];
		}, $leituracampos);

		$resultado = new LengthAwarePaginator(
			$dadosTratados,
			$totalRegistros,
			$porPagina,
			$paginaAtual,
			[
				'path' => $request->url(),
				'query' => $request->query()
			]
		);

		return view('dossie.default', compact('resultado'));
	}



	//BOTÃO GERAR DOSSIÊ DA TELA
	public function btnGerarDossie(Request $request)
	{


		//objetos criados ao longo deste código;
		$bancoteste = new TeseFormatada();
		$obArcherRest = new ArcherRest();
		$CriarWordxDossie = new WordxDossieController();

		//tempo definido tendo em vista que aguardar mais que 60s extoura; 
		set_time_limit(180);

		//1) PEGA OS DADOS PROCESSADOS PELO RELATÓRIO
		$jsonBruto = $request->input('processo_dados');
		$dadosDoProcesso = json_encode($jsonBruto) ? json_decode($jsonBruto, true) : [];
		$idPdf = $dadosDoProcesso['17684||'] ?? null;
		$idDocx = $dadosDoProcesso['20554||'] ?? null;
		$idDoSubsidio = $dadosDoProcesso['18156||'] ?? null;
		//A variavel $idDoSubsidio é usada também como nome da pasta;

		//2) USA A API DO LAZARO PARA EXTRAIR O TEXTO E PEGAR AS TESES
		$textoPeticaoInicial = $this->extrair_texto($idPdf);
		$extrairTeses = $this->analisarTeses($textoPeticaoInicial);

		//3) PEGA O NUMERO DAS TESES E BUSCA NO BANCO O TEXTO
		$teseslistabanco = $bancoteste->numeroTesesBanco($extrairTeses);

		//3.1) SINTESE FÁTICA (CAUSA DE PEDIR E OS PEDIDOS)
		$sintesefatica = $this->sinteseFatica($textoPeticaoInicial);

		//4) PEGA O ARQUIVO DO ARTÉRIA, EXTRAI, E CRIA O DOCX
		$arquivodcx =  $this->getSubsidioCliente($idDocx, $idDoSubsidio);
		$jsontextosubsidio =  $obArcherRest->extrairArquivo($arquivodcx, $idDoSubsidio);
		$criararquivo = $CriarWordxDossie->criarWordx($idDocx, $jsontextosubsidio, $teseslistabanco, $jsonBruto, $idDoSubsidio, $sintesefatica);
		//	dd($criararquivo);

		//5) GRAVA O ARQUIVO NO AMBIENTE DE HOMOLOGAÇÃO
		$caminho_limpo = str_replace('\\', '/', $criararquivo);
		$nomearquivo = basename($caminho_limpo);
		$partes = explode('automacao_dossie/' . $idDoSubsidio . '/', $caminho_limpo);
		$caminho = 'automacao_dossie/' . $idDoSubsidio . '/' . end($partes); //retorna "automacao_dossie/7230542/dossie_1014873583.docx"
		$uploadarquivo = $obArcherRest->addFile($nomearquivo, $caminho);
		$obArcherRest->updateArquivoContrato($idDoSubsidio, 28403, $uploadarquivo);

		//6) CRIA UM ARQUIVO DE LOG TXT NA MESMA PASTA
		$this->gerenciarLogDossie("");

		//7) APAGA TODO O CONTEÚDO DA PASTA /automacao_dossie
		$this->limparPastaDossieCompleto($caminho);

		//8) RETORNAR OS DADOS PARA A BLADE /dossie/gerar
		return view('dossie.dossie', [
			'mensagem' => "Id Criado em " . $idDoSubsidio
		]);
	}

	//ANALISAR TESES
	public function analisarTeses($texto)
	{

		$MapeamentoTeses = new PalavrasTeses(); // model do banco 
		$textoMinusculo = mb_strtolower($texto, 'UTF-8');

		$mapeamentoTeses = $MapeamentoTeses->dbMapeamentoteses();

		$resultado = [];
		foreach ($mapeamentoTeses as $tese) {
			$encontrou = false;
			$termos = json_decode($tese->termos, true);
			if (is_array($termos)) {
				foreach ($termos as $palavra) {
					if (str_contains($textoMinusculo, mb_strtolower($palavra, 'UTF-8'))) {
						$encontrou = true;
						break;
					}
				}
			}

			$resultado[$tese->nome] = [
				'status' => $encontrou,
				'field_id' => $tese->field_id
			];
		}

		// ========================================================================
		// 2. REGRAS ESPECIAIS (Lógica "E" e Anulações)
		// ========================================================================

		// REGRA PARA A TESE 38: Incompetência da Justiça Federal
		$enderecadoJusticaFederal = str_contains($textoMinusculo, 'justiça federal') ||
			str_contains($textoMinusculo, 'juiz federal') ||
			str_contains($textoMinusculo, 'vara federal');

		$contraSeguradoraPrivada = str_contains($textoMinusculo, 'caixa seguradora') ||
			str_contains($textoMinusculo, 'caixa vida e previdência') ||
			str_contains($textoMinusculo, 'caixa vida e previdencia') ||
			str_contains($textoMinusculo, 'vida e previdência') ||
			str_contains($textoMinusculo, 'direito privado');

		$resultado['[TESE-38] - DA INCOMPETÊNCIA DA JUSTIÇA FEDERAL PARA JULGAMENTO DO FEITO'] = [
			'status' => ($enderecadoJusticaFederal && $contraSeguradoraPrivada),
			'field_id' => '28350'
		];

		// REGRA DE CONFLITO: Se achou Venda Casada, anula a Repetição de Indébito
		if (isset($resultado['[TESE-25] - INEXISTÊNCIA DE VENDA CASADA']) && $resultado['[TESE-25] - INEXISTÊNCIA DE VENDA CASADA']['status'] === true) {
			if (isset($resultado['[TESE-39] - DA REPETIÇÃO DO INDÉBITO'])) {
				$resultado['[TESE-39] - DA REPETIÇÃO DO INDÉBITO']['status'] = false;
			}
		}

		// REGRA PARA A TESE 27: Ingresso Espontâneo
		$assuntoSeguro = str_contains($textoMinusculo, 'seguro prestamista') ||
			str_contains($textoMinusculo, 'seguro de vida') ||
			str_contains($textoMinusculo, 'previdência') ||
			str_contains($textoMinusculo, 'previdencia');

		$empresaPoloPassivoErrada = str_contains($textoMinusculo, 'caixa seguradora') ||
			str_contains($textoMinusculo, 'caixa econômica') ||
			str_contains($textoMinusculo, 'caixa economica') ||
			str_contains($textoMinusculo, 'cef') ||
			str_contains($textoMinusculo, 'xs2') ||
			str_contains($textoMinusculo, 'banco caixa') ||
			str_contains($textoMinusculo, '02.860.003/0001-51'); // CNPJ Caixa Seguradora

		$empresaPoloPassivoCerta = str_contains($textoMinusculo, 'caixa vida previdência') ||
			str_contains($textoMinusculo, 'caixa vida previdencia') ||
			str_contains($textoMinusculo, 'caixa vida e previdência') ||
			str_contains($textoMinusculo, 'caixa vida e previdencia') ||
			str_contains($textoMinusculo, '03.730.204/0001'); // Início do CNPJ da Caixa Vida

		// A tese só ativa se achou a Errada e NÃO (!) achou a Certa
		$resultado['[TESE-27] - PRELIMINAR DE INGRESSO ESPONTÂNEO'] = [
			'status' => ($assuntoSeguro && $empresaPoloPassivoErrada && !$empresaPoloPassivoCerta),
			'field_id' => '28340'
		];

		// REGRA PARA A TESE 20: Ilegitimidade Passiva para Recálculo
		$contraQualquerSeguradora = str_contains($textoMinusculo, 'caixa seguradora') ||
			str_contains($textoMinusculo, 'caixa vida e previdência') ||
			str_contains($textoMinusculo, 'caixa vida e previdencia') ||
			str_contains($textoMinusculo, 'vida e previdência') ||
			str_contains($textoMinusculo, '03.730.204/0001');

		$pedeRevisaoEmprestimo = str_contains($textoMinusculo, 'recálculo') ||
			str_contains($textoMinusculo, 'revisão de parcelas') ||
			str_contains($textoMinusculo, 'saldo devedor') ||
			str_contains($textoMinusculo, 'juros abusivos') ||
			str_contains($textoMinusculo, 'revisão do contrato de empréstimo');

		$resultado['[TESE-20] - ILEGITIMIDADE PASSIVA DA CAIXA VIDA E PREVIDÊNCIA QUANTO AO PEDIDO DE RECÁLCULO'] = [
			'status' => ($contraQualquerSeguradora && $pedeRevisaoEmprestimo),
			'field_id' => '28333'
		];

		// ========================================================================
		// 3. CONVERSÃO E RETORNO DOS DADOS
		// ========================================================================
		$tesesAtivas = [];

		foreach ($resultado as $chaveTese => $dadosTese) {
			if (isset($dadosTese['status']) && $dadosTese['status'] === true) {
				if (preg_match('/\[TESE-(\d+)\]/', $chaveTese, $matches)) {
					// O (int) já garante que o valor seja salvo como um número inteiro puro
					$tesesAtivas[] = (int)$matches[1];
				}
			}
		}

		return $tesesAtivas;
	}

	//BAIXAR O ARQUIVO BASE64
	private function getSubsidioCliente($Idarquivo, $nomeDaPasta)
	{
		$docsub = new ArcherRest;
		$respostaApi = $docsub->getPecaProd($Idarquivo);

		if (!is_array($respostaApi) || !isset($respostaApi['AttachmentBytes'])) {
			return ['erro' => $respostaApi];
		}

		$base64Data = $respostaApi['AttachmentBytes'];

		$conteudoBinario = base64_decode($base64Data);

		//anteriormente só apagava, agora verifica se já existe, e se existir apaga
		// $diretorio = 'uploads/' . $nomeDaPasta . '/';

		// if (!is_dir($diretorio)) {
		//   mkdir($diretorio, 0755, true);
		// }


		$diretorio = 'automacao_dossie/' . $nomeDaPasta . '/';
		function apagarDiretorio($dir)
		{
			if (!is_dir($dir)) {
				return false;
			}
			// array_diff é a interseção
			$arquivos = array_diff(scandir($dir), array('.', '..'));

			foreach ($arquivos as $arquivo) {
				$caminho = "$dir/$arquivo";
				is_dir($caminho) ? apagarDiretorio($caminho) : unlink($caminho);
			}
			return rmdir($dir);
		}

		if (is_dir($diretorio)) {
			apagarDiretorio($diretorio);
		}

		mkdir($diretorio, 0755, true);
		$nomeArquivo = 'subsidio' . rand(10000, 99999) . '.docx';
		$caminhoCompleto = $diretorio . $nomeArquivo;

		$sucesso = file_put_contents($caminhoCompleto, $conteudoBinario);

		if ($sucesso !== false) {
			return [
				'sucesso' => true,
				'mensagem' => 'Arquivo salvo com sucesso!',
				'nome_arquivo' => $nomeArquivo,
				'caminho' => $caminhoCompleto,
				'pasta' => $nomeDaPasta
			];

			return $mensagem;

			dd($sucesso);
		} else {
			return [
				'erro' => 'Não foi possível salvar o arquivo no servidor. Verifique as permissões da pasta.'
			];
		}
	}

